# ── Dylan's Notes — environment variables ───────────────────────────────
# Copy this file to `.env.local` for local dev, and set the same values in
# Vercel (Project → Settings → Environment Variables) for production.
# NEVER commit `.env.local` or real secrets. See README.md / CLAUDE.md.

# Notion internal integration token (Notion → Settings → Connections →
# Develop or manage integrations → New integration → Internal).
# Share the "Dylan's Notes" database AND the "Library" database with this
# integration so it can read both.
NOTION_TOKEN=secret_xxx

# Database IDs (see CLAUDE.md "Content model").
# NOTES holds all written content (Research Notes / Internships / Fieldnotes),
# split by the Type property. READING is Dylan's existing Library.
NOTION_DB_NOTES=2a666526496748c5b37353ca3b8b4420
NOTION_DB_READING=a6845e59614643bca767366cfb510a62

# Long random string that guards the on-demand revalidation endpoint.
# Generate with:  openssl rand -hex 32
REVALIDATE_SECRET=change-me-to-a-long-random-string
