# ── Dylan's Notes — environment variables ───────────────────────────────
# Copy this file to `.env.local` for local dev, and set the same values in
# Vercel (Project → Settings → Environment Variables) for production.
# NEVER commit `.env.local` or real secrets. See README.md / CLAUDE.md.

# Notion internal integration token (Notion → Settings → Connections →
# Develop or manage integrations → New integration → Internal).
# Share BOTH databases below with this integration (they sit in different
# places in the workspace — share each one).
NOTION_TOKEN=secret_xxx

# Database IDs (see CLAUDE.md "Content model"). These are database IDs, which is
# what @notionhq/client uses for databases.query.
#   CONTENT holds all written entries (Research Notes / Internships / Fieldnotes),
#   split by the Type property. LIBRARY is Dylan's existing reading list; only
#   books with Publish = true render on /reading.
NOTION_DB_CONTENT=2a666526496748c5b37353ca3b8b4420
NOTION_DB_LIBRARY=a6845e59614643bca767366cfb510a62

# Long random string that guards the on-demand revalidation endpoint.
# Generate with:  openssl rand -hex 32
REVALIDATE_SECRET=change-me-to-a-long-random-string
